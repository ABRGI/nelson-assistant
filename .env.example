# ---- Core ----
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ---- Web auth flow ----
# The bot hosts a one-time sign-in page so users never paste passwords in Slack.
# BASE_URL must be reachable by the user's browser (localhost works if they're on
# the same machine; ngrok / the prod ALB otherwise). PORT is the local listener.
AUTH_CALLBACK_PORT=3100
AUTH_CALLBACK_BASE_URL=http://localhost:3100

# ---- Storage selection ----
# fs = local filesystem (development). aws = S3 + Secrets Manager (staging/prod).
STORAGE_MODE=fs
LOCAL_STATE_ROOT=./.local-state
# Only needed when STORAGE_MODE=aws:
# STATE_BUCKET=nelson-assistant-state-dev

# ---- AWS ----
AWS_REGION=eu-west-1
AWS_PROFILE=nelson

# ---- Bedrock ----
BEDROCK_SONNET_MODEL_ID=eu.anthropic.claude-sonnet-4-6
BEDROCK_HAIKU_MODEL_ID=eu.anthropic.claude-haiku-4-5-20251001-v1:0

# ---- Secrets Manager names (aws mode only) ----
SECRETS_RUNTIME_NAME=nelson-assistant/runtime
SECRETS_USER_PREFIX=nelson-assistant/user
SECRETS_CLIENT_PREFIX=nelson-assistant/client

# ---- Git worktrees ----
# In dev, point at a local clone so no GitHub deploy key is needed:
WORKSPACE_ROOT=./.local-state/work
NELSON_REMOTE_URL=file:///home/sandeepbaynes/Documents/nelson/src/nelson
# Or specify multiple: PROJECT_REMOTES=nelson=file:///path,bui=git@github.com:...

# ---- Slack (dev inline creds; in prod these come from Secrets Manager) ----
# Get these from api.slack.com/apps → your app → Basic Information / OAuth & Permissions
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=xoxb-...
# Setting SLACK_APP_TOKEN enables Socket Mode — no public URL needed for local dev.
SLACK_APP_TOKEN=xapp-...

# ---- Escalation ----
# Your Slack user ID (found in your Slack profile → three dots → Copy member ID)
ESCALATION_SLACK_USER_ID=U12345678

# ---- Nelson global auth (shared across all tenants/envs) ----
# Both login and refresh-token exchange go through POST /api/user/login
# on user-management-service. No Cognito SDK client credentials needed.
NELSON_USER_MGMT_BASE_URL=https://admin.nelson.management
# Shown on the sign-in page: "Sign in to <NELSON_DISPLAY_NAME>".
NELSON_DISPLAY_NAME=Nelson

# ---- Database (observer / read-only) ----
# PostgreSQL connection string for the read-only observer role.
# Format: postgres://user:password@host:5432/dbname
# Leave blank to disable the psql tool.
PSQL_READ_ONLY_URL=

# ---- Tenant routing (Stage 1) ----
# Pick one registered tenant for every /nelson query. Omit if exactly one
# client record exists; required if you have more than one. V2 replaces this
# with per-query routing from JWT claims.
# DEFAULT_TENANT_ID=acme
# In prod these are read from the Secrets Manager runtime secret.
# For local dev generate your own with:
#   openssl rand -base64 32   (for TOKEN_ENCRYPTION_KEY — AES-256-GCM key)
#   openssl rand -base64 32   (for ID_HASH_KEY — HMAC-SHA256 key)
TOKEN_ENCRYPTION_KEY=
ID_HASH_KEY=
