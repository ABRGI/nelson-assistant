{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm list:*)",
      "Bash(npm outdated:*)",
      "Bash(npx vitest:*)",
      "Bash(npx tsc:*)",
      "Bash(npx playwright:*)",
      "Bash(node --version)",
      "Bash(node -v)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git worktree list)",
      "Bash(git worktree list:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cat:*)",
      "Bash(AWS_PROFILE=nelson aws sts get-caller-identity:*)",
      "Bash(AWS_PROFILE=nelson aws bedrock list-foundation-models:*)"
    ]
  },
  "env": {
    "NODE_ENV": "development"
  }
}
